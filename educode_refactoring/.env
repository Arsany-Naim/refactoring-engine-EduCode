# EduCode Refactoring Game — Environment Configuration Template

# Paste this template into a .env file in the educode_refactoring/ directory
# and fill in your values. Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────
GEMINI_API_KEY='Enter Your API Key Here'

# ── Optional ──────────────────────────────────────────────────────────────

# Flask Configuration
DEBUG=False
PORT=5001

# Session Storage TTL (seconds)
SESSION_STORE_TTL=7200

# GitHub OAuth (for GitHub Mode)
GITHUB_OAUTH_CLIENT_ID=your_github_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_app_secret

# Allowed GitHub Repositories (comma-separated pattern list, optional)
# Example: someuser/repo1,anotheruser/*
ALLOWED_REPOS=*

# CORS Settings (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:7777,http://127.0.0.1:7777

# ── How to Get Keys ───────────────────────────────────────────────────────

# Google Gemini:
#   1. Go to https://makersuite.google.com/app/apikeys
#   2. Click "Create API Key"
#   3. Copy the key here

# GitHub OAuth (optional, for GitHub Mode):
#   1. Go to https://github.com/settings/developers
#   2. Create a new OAuth App
#   3. Set Authorization callback URL to: http://localhost:5001/auth/github/callback
#   4. Copy Client ID and Secret here
